{
  "name": "scinexa-conferences",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "lint:web": "npm --workspace apps/web run lint",
    "dev:api": "mvn -f apps/api/pom.xml spring-boot:run",
    "build:api": "mvn -f apps/api/pom.xml clean package"
  }
}
